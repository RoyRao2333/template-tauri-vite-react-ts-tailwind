{
  "name": "tauri-app-workspace",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @app/tauri-app dev",
    "build": "pnpm --filter @app/tauri-app build",
    "preview": "pnpm --filter @app/tauri-app preview",
    "tauri": "pnpm --filter @app/tauri-app tauri",
    "rename-project": "tsx --tsconfig scripts/tsconfig.json scripts/renameProject.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/node": "22.19.19",
    "oxfmt": "0.51.0",
    "oxlint": "1.66.0",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.3"
  }
}
